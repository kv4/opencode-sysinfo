{
  "name": "opencode-sysinfo",
  "version": "1.0.1",
  "description": "OpenCode TUI plugin that shows system info (hostname, RAM, CPU, battery) in the sidebar",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/tui.tsx"
    },
    "./tui": {
      "import": "./dist/tui.tsx"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp src/tui.tsx src/utils.ts dist/",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0",
    "@opentui/core": ">=0.3.4",
    "@opentui/solid": ">=0.3.4",
    "solid-js": ">=1.9.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.13",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "bun-types": "latest",
    "esbuild-plugin-solid": "^0.6.0",
    "solid-js": "^1.9.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "opencode",
    "plugin",
    "tui",
    "sidebar",
    "system-info"
  ],
  "license": "MIT"
}
